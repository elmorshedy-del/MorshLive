# Copy to .env for local / cloud-agent deploys (this file is gitignored — never commit).
# NEVER commit real tokens to git or put them in HTML/JS.

# Create at: https://dash.cloudflare.com/profile/api-tokens
# Full scope list (current + future): config/cloudflare-api-token-scopes.json
# Template: "Edit Cloudflare Workers" + zone Workers Routes Edit on korazero.com
#   - Account → Workers Scripts → Edit  (required — deploy + secrets)
#   - Account → Account Settings → Read
#   - Zone korazero.com → Workers Routes → Edit
CLOUDFLARE_API_TOKEN=your_cfat_token_here

# Dashboard → any domain → right sidebar → Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Optional alias (also read if present in .env):
# CLOUDFLARE_TOKEN5=your_cfat_token_here

# Signed stream proxy secret — NOT read from this file. It is a Cloudflare Worker
# secret that keeps /wk/hls from blacking out on CDN host rotations. Set it once:
#   npx wrangler secret put STREAM_SIGNING_SECRET   (value: openssl rand -hex 32)
#
# YouTube Data API v3 key for Arabic replay clips (ملخص المباراة). Set as Worker
# secret AND GitHub Actions secret (YOUTUBE_API_KEY) — never commit the key.
#   npx wrangler secret put YOUTUBE_API_KEY
#
# X (Twitter) API v2 Bearer Token for viral match memes (tournament archive).
# Set on the Worker only — memes are fetched at runtime via /api/match-memes
# (edge-cached 30 min). GitHub Actions does NOT need this token.
#   npx wrangler secret put TWITTER_BEARER_TOKEN
#
# Twitch Helix (pure-TV relay picker). Create app at https://dev.twitch.tv/console/apps
# Automated crawl (Crawlee + Playwright — https://github.com/apify/crawlee):
#   npm run browsers:install
#   TWITCH_LOGIN_EMAIL=you@example.com HEADFUL=1 npm run crawl:twitch-dev
# Then add credentials and push to worker:
#   node scripts/setup-twitch-secrets.mjs
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# Optional local archive bake (not required for production):
#   TWITTER_BEARER_TOKEN='…' node scripts/fetch-tournament-archive.js
# Without a bearer token, the archive refresh still uses public X syndication.
