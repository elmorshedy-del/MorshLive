# Copy to .env for local Wrangler deploys (this file is gitignored).
# NEVER commit real tokens to git or put them in HTML/JS.

# Create at: https://dash.cloudflare.com/profile/api-tokens
# Template: "Edit Cloudflare Workers" or custom with:
#   - Account → Cloudflare Pages → Edit
#   - Account → Account Settings → Read
CLOUDFLARE_API_TOKEN=your_token_here

# Dashboard → any domain → right sidebar → Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
